rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default rule: Allow read for authenticated users
    match /{document=**} {
      allow read: if request.auth != null;
    }
    
    // Protect against bill-inflating by restricting size/structure on massive collections like expenses
    match /expenses/{expenseId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null 
                            && request.resource.data.keys().hasAny(['totalAmount', 'createdAt'])
                            && request.resource.data.totalAmount >= 0; // basic validation
      allow delete: if request.auth != null;
    }

    match /users/{userId} {
      allow read, write: if request.auth != null;
    }

    match /{collection}/{docId} {
      allow write: if request.auth != null && collection != 'expenses' && collection != 'users';
    }
  }
}
